      <units>RPM</units>
      <decimalpl>0</decimalpl>
      <min>0.000000</min>
      <max>15000.000000</max>
      <outputtype>1</outputtype>
      <MATH equation="X">
        <VAR id="X" />
      </MATH>
    </XDFAXIS>
  </XDFTABLE>
  <XDFTABLE uniqueid="0x0004" flags="0x30">
    <title>Rev Limiter</title>
