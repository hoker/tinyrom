# Public examples live under examples/
# These negations re-include synthetic sample fixtures ONLY under examples/.
# Proprietary .xdf/.bin elsewhere stay ignored.
!examples/
!examples/*.bin
!examples/*.toml
!examples/*.xml
!examples/*.xdf
